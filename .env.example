# TrustRAG 环境变量模板
# 复制为 .env 并填入实际值

# ======== 后端服务 ========
LISTEN_ADDR=0.0.0.0:8080
RUST_LOG=trustrag_backend=debug,tower_http=debug

# ======== 数据库 ========
DATABASE_URL=postgres://trustrag:trustrag_dev@localhost:5432/trustrag
POSTGRES_USER=trustrag
POSTGRES_PASSWORD=trustrag_dev
POSTGRES_DB=trustrag

# ======== Redis ========
REDIS_URL=redis://localhost:6379

# ======== MinIO ========
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=trustrag
MINIO_SECRET_KEY=trustrag_dev_secret
MINIO_BUCKET=trustrag-files
MINIO_ROOT_USER=trustrag
MINIO_ROOT_PASSWORD=trustrag_dev_secret

# ======== JWT ========
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRY_HOURS=24

# ======== 文档处理服务 ========
DOC_PROCESSOR_URL=http://localhost:8081

# ======== LLM (可选，用户在 UI 配置) ========
# DEFAULT_LLM_API_BASE=http://localhost:11434/v1
# DEFAULT_LLM_API_KEY=
# DEFAULT_LLM_MODEL=qwen2.5:72b

# ======== Embedding (可选) ========
# EMBEDDING_PROVIDER=local
# EMBEDDING_MODEL=nomic-embed-text-v2
# OPENAI_API_KEY=sk-...
